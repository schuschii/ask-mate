# Ignore .idea (PhpStorm project settings)
.idea/

# Ignore vendor folder (Composer dependencies)
vendor/

# Ignore environment and configuration files
.env
.env.local
.env.*.local
*.ini
config/config.local.json

# Ignore logs and cache
logs/
*.log
cache/
tmp/

# Ignore PHPUnit and coverage reports
phpunit.xml
phpunit.xml.dist
coverage/
clover.xml

# Ignore documentation generated by phpDocumentor
#docs/

# Ignore uploaded files (if applicable)
public/uploads/
storage/uploads/

# Ignore database files (if using SQLite)
*.sqlite
*.sqlite3
database/database.sqlite

# Ignore compiled files
*.pyc
*.pyo
*.exe
*.dll
*.so
*.o
*.a
*.out
*.class

# Ignore system files
.DS_Store
Thumbs.db
*.swp
*.swo

# Ignore Composer lock file if using a library (not an application)
# /composer.lock

# Ignore node_modules (if using Node.js for frontend assets)
node_modules/

# Ignore build files (if using frontend tools like Webpack, Vite, etc.)
dist/
build/

# Ignore phpDocumentor
phpDocumentor.phar
